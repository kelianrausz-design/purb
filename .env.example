# Copie ce fichier en .env et remplis les valeurs

# Anthropic (obligatoire) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Genius (obligatoire) — https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=...

# Serper.dev (recommandé) — https://serper.dev
# Utilisé pour trouver les handles Instagram via Google Search
SERPER_API_KEY=...

# Apify (recommandé) — https://apify.com
# Utilisé pour scraper les profils Instagram ($0.003/profil)
APIFY_API_TOKEN=...
